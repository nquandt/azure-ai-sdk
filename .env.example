# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real values.

# ---------------------------------------------------------------------------
# Azure AI Foundry — resource and project
# resourceName: the subdomain portion (e.g. my-resource)
# projectId:    the project name under that resource
# Together they construct:
#   https://{AZURE_FOUNDRY_RESOURCE}.services.ai.azure.com/api/projects/{AZURE_FOUNDRY_PROJECT}
#
# Alternatively, set AZURE_AI_FOUNDRY_ENDPOINT to provide the full URL directly.
# ---------------------------------------------------------------------------
AZURE_FOUNDRY_RESOURCE=
AZURE_FOUNDRY_PROJECT=

# Deployment name to use in integration tests (must exist on the resource above)
AZURE_FOUNDRY_MODEL=

# Optional API key — when set, used directly as the Bearer token (skips az login)
AZURE_FOUNDRY_API_KEY=

# ---------------------------------------------------------------------------
# APIM gateway endpoint (optional — tests are skipped if not set)
# Format: https://<apim-name>.azure-api.net/<api-path>
# ---------------------------------------------------------------------------
AZURE_APIM_ENDPOINT=

# Deployment/model name accessible through the APIM gateway
AZURE_APIM_MODEL=

# OAuth2 scope for the APIM gateway token.
# Use the app registration scope until the APIM validate-jwt policy is updated
# to accept https://cognitiveservices.azure.com or https://ai.azure.com tokens.
# See docs/apim-integration.md for details.
AZURE_APIM_SCOPE=

# ---------------------------------------------------------------------------
# Authentication
# All tests use DefaultAzureCredential — no key needed.
# Run: az login --tenant <your-tenant-id>
# ---------------------------------------------------------------------------
