{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "azure-foundry": {
      "npm": "@nquandt/azure-ai-sdk",
      "name": "Azure AI Foundry",
      "options": {
        "resourceName": "<your-foundry-resource-name>",
        "projectId": "<your-project-id>",
        "apiKey": "<optional-api-key-or-use-az-login>",
        "debugLogFile": "<optional-absolute-path-to-debug.log>"
      },
      "models": {
        "gpt-5.4-nano": {
          "name": "GPT-5.4 Nano"
        }
      }
    }
  },
  "model": "azure-foundry/gpt-5.4-nano",
  "small_model": "azure-foundry/gpt-5.4-nano"
}
